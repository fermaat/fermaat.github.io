---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import { getCollection } from "astro:content";

const allProjects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div class="mb-6">
    <div class="text-3xl font-bold mb-2">Projects</div>
    <p class="opacity-80">
      A selection of experimental labs, production systems, and educational work. Links open the
      project detail page; the GitHub repo is inside.
    </p>
  </div>

  <div class="flex flex-wrap -mx-6">
    {
      allProjects.map((project) => (
        <Card
          title={project.data.title}
          desc={project.data.description}
          url={`/projects/${project.slug}`}
          target="_self"
          tags={project.data.tech.slice(0, 4)}
          badge={project.data.featured ? "FEATURED" : undefined}
        />
      ))
    }
  </div>
</BaseLayout>
