---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "./Card.astro";
import HorizontalCard from "./HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";
import { t, type Locale } from "../i18n/strings";
import { localizePath } from "../i18n/utils";

interface Props { locale?: Locale }
const { locale = "en" } = Astro.props as Props;
const s = t(locale);

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const last_posts = posts.slice(0, 3);

const allProjects = await getCollection("projects");
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const projectsHref = localizePath("/projects", locale);
const blogHref = "/blog/";
---

<BaseLayout sideBarActiveItemID="home">
  <!-- Hero -->
  <div class="pb-10 mt-5">
    <div class="text-xl py-1 opacity-80">{s.hero.greeting}</div>
    <div class="text-5xl font-bold">Fernando Velasco Lozano</div>
    <div class="text-2xl py-3 font-bold opacity-90">{s.hero.role}</div>
    <div class="py-2">
      <p class="text-lg leading-relaxed" set:html={s.hero.lead_html}></p>
    </div>
    <div class="mt-6 flex flex-wrap gap-3">
      <a class="btn btn-primary" href={projectsHref}>{s.hero.cta_projects}</a>
      <a class="btn btn-outline" href="/files/CV.pdf" target="_blank" rel="noopener">{s.hero.cta_cv}</a>
      <a class="btn btn-ghost" href="mailto:fermaat.vl@gmail.com">{s.hero.cta_contact}</a>
    </div>
  </div>

  <div class="divider my-2"></div>

  <!-- Featured projects -->
  <div class="mt-4">
    <h2 class="text-3xl w-full font-bold mb-4">{s.sections.featured_projects}</h2>
    <div class="flex flex-wrap -mx-6">
      {
        featuredProjects.map((project) => (
          <Card
            title={locale === "es" ? (project.data.title_es ?? project.data.title) : project.data.title}
            img={project.data.image}
            desc={locale === "es" ? (project.data.description_es ?? project.data.description) : project.data.description}
            url={`${localizePath("/projects", locale)}/${project.slug}`}
            target="_self"
            tags={project.data.tech.slice(0, 3)}
          />
        ))
      }
    </div>
    <div class="mt-6">
      <a href={projectsHref} class="link link-hover opacity-80">{s.sections.see_all_projects}</a>
    </div>
  </div>

  <div class="divider my-6"></div>

  <!-- Latest writing -->
  <div>
    <h2 class="text-3xl w-full font-bold mb-4">{s.sections.latest_writing}</h2>
    {
      last_posts.map((post) => (
        <>
          <HorizontalCard
            title={post.data.title}
            img={post.data.heroImage}
            desc={post.data.description}
            url={"/blog/" + createSlug(post.data.title, post.slug)}
            target="_self"
            badge={post.data.badge}
          />
          <div class="divider my-0" />
        </>
      ))
    }
    <div class="mt-4">
      <a href={blogHref} class="link link-hover opacity-80">{s.sections.see_all_posts}</a>
    </div>
  </div>

  <div class="divider my-6"></div>

  <!-- Current research -->
  <div>
    <h2 class="text-3xl w-full font-bold mb-4">{s.sections.research}</h2>
    <p class="text-base mb-4 opacity-90">{s.sections.research_intro}</p>
    <ul class="list-disc pl-6 space-y-3 text-base">
      {
        s.sections.research_items.map((item) => (
          <li>
            <b>{item.title}</b> — {item.body}
          </li>
        ))
      }
    </ul>
  </div>

  <div class="divider my-6"></div>

  <!-- Awards -->
  <div>
    <h2 class="text-3xl w-full font-bold mb-4">{s.sections.awards}</h2>
    <div class="card bg-base-200">
      <div class="card-body">
        <h3 class="card-title text-lg font-semibold">
          {s.sections.awards_title} ·
          <a
            href="https://somosnlp.org/blog/hackathon-2022"
            target="_blank"
            class="link link-hover"
          >
            {s.sections.awards_venue}
          </a>
        </h3>
        <p class="opacity-90">{s.sections.awards_body}</p>
      </div>
    </div>
  </div>
</BaseLayout>
