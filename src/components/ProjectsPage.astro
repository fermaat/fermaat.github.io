---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "./Card.astro";
import { getCollection } from "astro:content";
import { t, type Locale } from "../i18n/strings";
import { localizePath } from "../i18n/utils";

interface Props { locale?: Locale }
const { locale = "en" } = Astro.props as Props;
const s = t(locale);

const allProjects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title={s.projects_page.title} sideBarActiveItemID="projects">
  <div class="mb-6">
    <h1 class="text-3xl font-bold mb-2">{s.projects_page.title}</h1>
    <p class="opacity-80">{s.projects_page.intro}</p>
  </div>

  <div class="flex flex-wrap -mx-6">
    {
      allProjects.map((project) => (
        <Card
          title={locale === "es" ? (project.data.title_es ?? project.data.title) : project.data.title}
          img={project.data.image}
          desc={locale === "es" ? (project.data.description_es ?? project.data.description) : project.data.description}
          url={`${localizePath("/projects", locale)}/${project.slug}`}
          target="_self"
          tags={project.data.tech.slice(0, 4)}
          badge={project.data.featured ? s.project_detail.featured_badge : undefined}
        />
      ))
    }
  </div>
</BaseLayout>
